#include "resource.h"
#include <windows.h>

LANGUAGE LANG_NEUTRAL, SUBLANG_NEUTRAL

/////////////////////////////////////////////////////////////////////////////
//
// Dialog
//

IDD_PIN_PROMPT DIALOGEX 0, 0, 220, 100
STYLE DS_SETFONT | DS_MODALFRAME | DS_FIXEDSYS | DS_CENTER | WS_POPUP | WS_CAPTION | WS_SYSMENU
CAPTION "Smart Card PIN"
FONT 8, "MS Shell Dlg", 400, 0, 0x1
BEGIN
    LTEXT           "",IDC_PIN_PROMPT_LABEL,14,14,192,10
    EDITTEXT        IDC_PIN_EDIT,14,30,192,14,ES_PASSWORD | ES_AUTOHSCROLL
    DEFPUSHBUTTON   "OK",IDOK,103,74,50,14
    PUSHBUTTON      "Cancel",IDCANCEL,159,74,50,14
END

/////////////////////////////////////////////////////////////////////////////
//
// Version
//

VS_VERSION_INFO VERSIONINFO
 FILEVERSION 1,0,0,0
 PRODUCTVERSION 1,0,0,0
 FILEFLAGSMASK 0x3fL
#ifdef _DEBUG
 FILEFLAGS 0x1L
#else
 FILEFLAGS 0x0L
#endif
 FILEOS 0x40004L
 FILETYPE 0x1L
 FILESUBTYPE 0x0L
BEGIN
    BLOCK "StringFileInfo"
    BEGIN
        BLOCK "040904b0"
        BEGIN
            VALUE "CompanyName", "EIDAuthentication"
            VALUE "FileDescription", "EIDAuthentication Credential Migration Tool"
            VALUE "FileVersion", "1.0.0.0"
            VALUE "InternalName", "EIDMigrate"
            VALUE "LegalCopyright", "Copyright (C) 2026"
            VALUE "OriginalFilename", "EIDMigrate.exe"
            VALUE "ProductName", "EIDAuthentication"
            VALUE "ProductVersion", "1.0.0.0"
        END
    END
    BLOCK "VarFileInfo"
    BEGIN
        VALUE "Translation", 0x409, 1200
    END
END

/////////////////////////////////////////////////////////////////////////////
//
// String Table
//

STRINGTABLE
BEGIN
    IDS_APP_NAME            "EIDMigrate"
    IDS_APP_VERSION         "1.0.0.0"
    IDS_APP_COPYRIGHT       "Copyright (C) 2026"
    IDS_ERROR_PASSPHRASE_SHORT    "Passphrase must be at least 16 characters."
    IDS_ERROR_PASSPHRASE_WEAK     "Passphrase should contain mixed case, numbers, and symbols for better security."
    IDS_ERROR_FILE_READ      "Failed to read file."
    IDS_ERROR_FILE_WRITE     "Failed to write file."
    IDS_ERROR_INVALID_FORMAT "Invalid file format."
    IDS_ERROR_LSA_ACCESS_DENIED "Access denied. Administrator privileges required."
    IDS_ERROR_NO_CREDENTIALS "No credentials found."
    IDS_INFO_EXPORT_COMPLETE "Export completed successfully."
    IDS_INFO_IMPORT_COMPLETE "Import completed successfully."
    IDS_WARNING_DPAPI_SKIPPED   "Skipped DPAPI-encrypted credentials (cannot be migrated)."
    IDS_WARNING_CERT_NOT_TRUSTED "Certificate trust warning."
    IDS_WARNING_GROUP_NOT_FOUND  "Group not found on target machine."
END
